{
  "name": "loopflow-backend",
  "version": "1.0.0",
  "private": true,
  "description": "LoopFlow backend — Cloudflare Workers (clean architecture, D1 + KV + R2)",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply loopflow --local",
    "db:migrate:remote": "wrangler d1 migrations apply loopflow --remote",
    "test": "vitest run"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240605.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "wrangler": "^3.78.0"
  }
}
